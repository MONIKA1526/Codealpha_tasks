          <span>❤️ ${post.likesCount} Likes</span>
          <span>💬 ${post.commentsCount} Comments</span>
        </div>
      </div>
    `).join('');
  } catch (error) {
    showAlert('❌ Error loading user posts', 'error');
  }
}
