// ==================== DISPLAY PAGINATION ====================
function displayPagination(currentPageNum, totalPages) {
  const pagination = document.getElementById('pagination');

  if (!pagination) {
    console.error('Pagination container not found');
    return;
  }

  // If only one page, don't show pagination
  if (totalPages <= 1) {
    pagination.innerHTML = '';
    return;
  }

  let html = '';

  // Previous buttons
  if (currentPageNum > 1) {
    html += `<a onclick="loadPostsPage(1)" style="cursor: pointer;">« First</a>`;
    html += `<a onclick="loadPostsPage(${currentPageNum - 1})" style="cursor: pointer;">‹ Previous</a>`;
  }

  // Page numbers
  const startPage = Math.max(1, currentPageNum - 2);
  const endPage = Math.min(totalPages, currentPageNum + 2);

  for (let i = startPage; i <= endPage; i++) {
    if (i === currentPageNum) {
      html += `<span class="active">${i}</span>`;
    } else {
      html += `<a onclick="loadPostsPage(${i})" style="cursor: pointer;">${i}</a>`;
    }
  }

  // Next buttons
  if (currentPageNum < totalPages) {
    html += `<a onclick="loadPostsPage(${currentPageNum + 1})" style="cursor: pointer;">Next ›</a>`;
    html += `<a onclick="loadPostsPage(${totalPages})" style="cursor: pointer;">Last »</a>`;
  }

  pagination.innerHTML = html;
}

// ==================== LOAD POSTS PAGE ====================
function loadPostsPage(page) {
  if (!page || page < 1) {
    showAlert('❌ Invalid page number', 'error');
    return;
  }

  loadPosts(page);
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

