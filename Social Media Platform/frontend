const API_URL = 'http://localhost:5000/api';
let currentPage = 1;

// Check authentication
function checkAuth() {
  const token = localStorage.getItem('token');
  const user = JSON.parse(localStorage.getItem('user'));

  const authLinks = document.getElementById('authLinks');
  const userLinks = document.getElementById('userLinks');
  const postCreator = document.getElementById('postCreator');

  if (token && user) {
    if (authLinks) authLinks.style.display = 'none';
    if (userLinks) userLinks.style.display = 'flex';
    if (postCreator) postCreator.style.display = 'block';
  } else {
    if (authLinks) authLinks.style.display = 'flex';
    if (userLinks) userLinks.style.display = 'none';
    if (postCreator) postCreator.style.display = 'none';
  }
}

function logout() {
  localStorage.removeItem('token');
  localStorage.removeItem('user');
  showAlert('Logged out successfully!', 'success');
  setTimeout(() => {
    window.location.href = 'index.html';
  }, 1500);
}

function showAlert(message, type = 'info') {
  const alertDiv = document.createElement('div');
  alertDiv.className = `alert alert-${type}`;
  alertDiv.innerHTML = `
    <strong>${type === 'success' ? '✅' : type === 'error' ? '❌' : 'ℹ️'}</strong>
    ${message}
  `;

  const body = document.body;
  body.insertAdjacentElement('afterbegin', alertDiv);

  setTimeout(() => {
    alertDiv.remove();
  }, 3000);
}

function getAuthToken() {
  return localStorage.getItem('token');
}

function getAuthHeaders() {
  return {
    'Content-Type': 'application/json',
    'Authorization': `Bearer ${getAuthToken()}`,
  };
}

function isLoggedIn() {
  return !!getAuthToken();
}

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  checkAuth();
});
// REGISTER
const registerForm = document.getElementById('registerForm');
if (registerForm) {
  registerForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    const username = document.getElementById('username').value.trim();
    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value;
    const confirmPassword = document.getElementById('confirmPassword').value;

    if (!username || !email || !password) {
      showAlert('All fields are required', 'error');
      return;
    }

    if (password !== confirmPassword) {
      showAlert('Passwords do not match', 'error');
      return;
    }

    if (password.length < 6) {
      showAlert('Password must be at least 6 characters', 'error');
      return;
    }

    try {
      const response = await fetch(`${API_URL}/auth/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, email, password, confirmPassword }),
      });

      const data = await response.json();

      if (!response.ok) {
        showAlert(data.error || 'Registration failed', 'error');
        return;
      }

      localStorage.setItem('token', data.token);
      localStorage.setItem('user', JSON.stringify(data.user));

      showAlert('✅ Registration successful! Redirecting...', 'success');
      setTimeout(() => {
        window.location.href = '../index.html';
      }, 2000);
    } catch (error) {
      showAlert('An error occurred. Please try again.', 'error');
    }
  });
}

// LOGIN
const loginForm = document.getElementById('loginForm');
if (loginForm) {
  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value;

    if (!email || !password) {
      showAlert('Email and password are required', 'error');
      return;
    }

    try {
      const response = await fetch(`${API_URL}/auth/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });

      const data = await response.json();

      if (!response.ok) {
        showAlert(data.error || 'Login failed', 'error');
        return;
      }

      localStorage.setItem('token', data.token);
      localStorage.setItem('user', JSON.stringify(data.user));

      showAlert('✅ Login successful! Redirecting...', 'success');
      setTimeout(() => {
        window.location.href = '../index.html';
      }, 2000);
    } catch (error) {
      showAlert('An error occurred. Please try again.', 'error');
    }
  });
}
// ==================== CREATE POST ====================
async function createPost() {
  if (!isLoggedIn()) {
    showAlert('❌ Please login to create a post', 'error');
    return;
  }

  const postContentElement = document.getElementById('postContent');
  if (!postContentElement) {
    showAlert('❌ Post form not found', 'error');
    return;
  }

  const content = postContentElement.value.trim();

  if (!content) {
    showAlert('❌ Post content cannot be empty', 'error');
    return;
  }

  if (content.length > 280) {
    showAlert('❌ Post cannot exceed 280 characters', 'error');
    return;
  }

  try {
    const response = await fetch(`${API_URL}/posts`, {
      method: 'POST',
      headers: getAuthHeaders(),
      body: JSON.stringify({ content }),
    });

    const data = await response.json();

    if (!response.ok) {
      showAlert(`❌ ${data.error || 'Failed to create post'}`, 'error');
      return;
    }

    // Clear form
    postContentElement.value = '';
    const charCountElement = document.getElementById('charCount');
    if (charCountElement) {
      charCountElement.textContent = '0';
    }

    showAlert('✅ Post created successfully!', 'success');
    loadPosts(1);
  } catch (error) {
    console.error('Error creating post:', error);
    showAlert('❌ Error creating post', 'error');
  }
}

// ==================== LOAD POSTS ====================
async function loadPosts(page = 1) {
  try {
    if (!API_URL) {
      showAlert('❌ API URL not configured', 'error');
      return;
    }

    const response = await fetch(`${API_URL}/posts?page=${page}&limit=10`);
    
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }

    const data = await response.json();

    displayPosts(data.posts || []);
    displayPagination(page, data.totalPages || 1);
    loadSuggestedUsers();
    currentPage = page;
  } catch (error) {
    console.error('Error loading posts:', error);
    showAlert('❌ Error loading posts', 'error');
  }
}

// ==================== DISPLAY POSTS ====================
function displayPosts(posts) {
  const feed = document.getElementById('postsFeed');

  if (!feed) {
    console.error('Posts feed container not found');
    return;
  }

  if (!posts || posts.length === 0) {
    feed.innerHTML = '<div class="no-posts"><p>📭 No posts yet. Be the first to post!</p></div>';
    return;
  }

  const currentUser = JSON.parse(localStorage.getItem('user') || '{}');

  try {
    feed.innerHTML = posts.map(post => {
      // Safely get post data
      const postId = post._id || '';
      const authorName = post.author?.username || 'Unknown';
      const authorId = post.author?._id || '';
      const authorImage = post.author?.profileImage || '👤';
      const postContent = escapeHtml(post.content || '');
      const createdDate = new Date(post.createdAt).toLocaleDateString();
      const likesCount = post.likesCount || 0;
      const commentsCount = post.commentsCount || 0;
      const comments = post.comments || [];
      const isOwnPost = authorId === currentUser.id;

      return `
        <div class="post-card" data-post-id="${postId}">
          <div class="post-header">
            <div class="post-avatar">${authorImage}</div>
            <div class="post-author-info">
              <div class="post-author" onclick="viewProfile('${authorName}')" style="cursor: pointer;">
                ${authorName}
              </div>
              <div class="post-time">${createdDate}</div>
            </div>
          </div>

          <div class="post-content">${postContent}</div>

          <div class="post-stats">
            <span>❤️ ${likesCount} Likes</span>
            <span>💬 ${commentsCount} Comments</span>
          </div>

          <div class="post-actions">
            <button class="action-btn" onclick="likePost('${postId}')" style="cursor: pointer;">❤️ Like</button>
            <button class="action-btn" onclick="toggleComments('${postId}')" style="cursor: pointer;">💬 Comment</button>
            ${isOwnPost ? `
              <button class="action-btn" onclick="deletePost('${postId}')" style="cursor: pointer;">🗑️ Delete</button>
            ` : ''}
          </div>

          <div id="comments-${postId}" class="comments-section" style="display:none;">
            <div class="comment-form">
              <input type="text" placeholder="💬 Add a comment..." id="comment-input-${postId}" />
              <button class="btn btn-primary" style="padding: 6px 16px; font-size: 0.9rem; width: auto; cursor: pointer;" onclick="addComment('${postId}')">Post</button>
            </div>
            <div id="comments-list-${postId}">
              ${comments.map(comment => `
                <div class="comment">
                  <div class="comment-author">${escapeHtml(comment.author?.username || 'Unknown')}</div>
                  <div class="comment-content">${escapeHtml(comment.content || '')}</div>
                </div>
              `).join('')}
            </div>
          </div>
        </div>
      `;
    }).join('');
  } catch (error) {
    console.error('Error displaying posts:', error);
    feed.innerHTML = '<p style="text-align: center; color: red;">❌ Error displaying posts</p>';
  }
