  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CodeAlpha E-Commerce Store</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  <!-- Navigation -->
  <nav class="navbar">
    <div class="container">
      <div class="nav-brand">
        <h1>🛍️ CodeAlpha Store</h1>
      </div>
      <ul class="nav-menu">
        <li><a href="index.html" class="active">Home</a></li>
        <li><a href="#products">Products</a></li>
        <li><a href="pages/cart.html" class="cart-link">🛒 Cart <span class="cart-count">0</span></a></li>
        <li id="authLinks">
